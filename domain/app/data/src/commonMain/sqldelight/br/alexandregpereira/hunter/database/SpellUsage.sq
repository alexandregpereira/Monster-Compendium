CREATE TABLE IF NOT EXISTS SpellUsageEntity (`spellUsageId` TEXT NOT NULL, `group` TEXT NOT NULL, `parentId` TEXT NOT NULL, PRIMARY KEY(`spellUsageId`));

CREATE INDEX IF NOT EXISTS index_SpellUsageEntity_parentId ON SpellUsageEntity (parentId);

insert:
INSERT OR REPLACE INTO SpellUsageEntity VALUES ?;

deleteWithParentId:
DELETE FROM SpellUsageEntity WHERE parentId IN ?;

getByParentIds:
SELECT * FROM SpellUsageEntity WHERE parentId IN ?;
